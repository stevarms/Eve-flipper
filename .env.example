# Example environment variables for local development / source builds
#
# By default, EVE SSO is disabled when building from source. To enable it,
# create a local .env (or set env vars in your shell) with your own EVE
# dev application credentials:
#
# 1. Go to https://developers.eveonline.com/
# 2. Create an application (Authentication Only)
# 3. Set Callback URL to: http://localhost:13370/api/auth/callback
# 4. Copy Client ID / Client Secret below.
#
# IMPORTANT: Never commit your real values to git.

ESI_CLIENT_ID=your-client-id-here
ESI_CLIENT_SECRET=your-client-secret-here
ESI_CALLBACK_URL=http://localhost:13370/api/auth/callback

# Hosted telemetry is disabled by default. Enable only on the public hosted Pi.
# Paid hosted UI/API is disabled unless EVEFLIPPER_HOSTED=true is set explicitly.
EVEFLIPPER_HOSTED=false
TELEMETRY_ENABLED=false
TELEMETRY_ENDPOINT=http://127.0.0.1:13371/v1/events
TELEMETRY_API_KEY=
TELEMETRY_SALT=
TELEMETRY_ENV=hosted

